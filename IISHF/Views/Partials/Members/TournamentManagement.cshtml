@using System.Text.Encodings.Web

<div id="tournamentManagementRoot" class="col-12 col-sm-12 col-md-12 col-lg-12 mb-5">

    <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
        <h4 class="mb-0">Tournament Management</h4>

        <div class="ms-auto d-flex flex-wrap gap-2 align-items-center">
            <button type="button" id="tmRefreshBtn" class="btn btn-outline-secondary">Refresh</button>
        </div>
    </div>

    <div id="tmError" class="alert alert-danger d-none"></div>
    <div id="tmSuccess" class="alert alert-success d-none"></div>

    <div class="row g-4">
        <div class="col-12 col-lg-6">
            <div class="mb-3">
                <label class="form-label">Current-year event</label>
                <select id="tmEventSelect" class="form-select"></select>
                <div class="small text-muted mt-1">
                    <span id="tmEventMeta"></span>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Search team</label>
                <div class="d-flex gap-2">
                    <input type="text" id="tmTeamSearch" class="form-control" placeholder="Search reported team name..." />
                    <button type="button" id="tmTeamSearchBtn" class="btn btn-primary">Search</button>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th>Reported team</th>
                            <th style="width:90px;">Id</th>
                            <th>Key</th>
                            <th style="width:170px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="tmReportedRows">
                        <tr><td colspan="4">Select an event and NMA, then search.</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="mb-3">
                <label class="form-label">National Member Association</label>
                <select id="tmNmaSelect" class="form-select"></select>
                <div class="small text-muted mt-1">
                    <span id="tmNmaMeta"></span>
                </div>
            </div>

            <div class="d-flex align-items-center justify-content-between mb-2">
                <div class="fw-semibold">Tournament teams in selected event</div>
                <button type="button" id="tmReloadTeamsBtn" class="btn btn-outline-secondary btn-sm">Reload</button>
            </div>

            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th>Tournament team</th>
                            <th style="width:80px;">ISO3</th>
                            <th style="width:90px;">Mapped?</th>
                            <th style="width:70px;">Select</th>
                        </tr>
                    </thead>
                    <tbody id="tmTournamentRows">
                        <tr><td colspan="4">Select an event to load teams.</td></tr>
                    </tbody>
                </table>
            </div>

            <div class="small text-muted mt-2">
                Linking keeps the tournament team name unchanged (e.g. <em>IHC La Broye</em>) but stores the reported team Id/Key + NMA key + ISO3.
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        var state = {
            events: [],
            nmas: [],
            selectedEventYearKey: null,
            selectedEventYear: null,
            selectedAgeGroup: null,
            selectedNmaKey: null,
            selectedNmaIso3: null,
            sourceYear: null,
            tournamentTeams: []
        };

        function showError(msg) {
            var el = $("#tmError");
            el.text(msg || "An error occurred.");
            el.removeClass("d-none");
        }

        function clearError() {
            $("#tmError").addClass("d-none").text("");
        }

        function showSuccess(msg) {
            var el = $("#tmSuccess");
            el.text(msg || "Saved.");
            el.removeClass("d-none");
            setTimeout(function () { el.addClass("d-none").text(""); }, 2500);
        }

        function clearSuccess() {
            $("#tmSuccess").addClass("d-none").text("");
        }

        function escapeHtml(text) {
            return $("<div/>").text(text ?? "").html();
        }

        function setMeta() {
            var eventMeta = "";
            if (state.selectedAgeGroup && state.selectedEventYear) {
                eventMeta = "Age group: " + state.selectedAgeGroup + "  |  Year: " + state.selectedEventYear;
            }
            $("#tmEventMeta").text(eventMeta);

            var nmaMeta = "";
            if (state.sourceYear) {
                nmaMeta = "Source year (reported): " + state.sourceYear;
            }
            $("#tmNmaMeta").text(nmaMeta);
        }

        function renderEvents() {
            var sel = $("#tmEventSelect");
            if (!state.events || state.events.length === 0) {
                sel.html('<option value="">No current-year events found</option>');
                state.selectedEventYearKey = null;
                state.selectedEventYear = null;
                state.selectedAgeGroup = null;
                setMeta();
                return;
            }

            var html = '<option value="">-- Select event --</option>';
            state.events.forEach(function (e) {
                var label = (e.category || "") + " - " + (e.tournamentName || "") + " (" + (e.year || "") + ")";
                html += '<option value="' + escapeHtml(e.eventYearNodeKey) + '" data-year="' + escapeHtml(e.year) + '" data-agegroup="' + escapeHtml(e.ageGroup) + '">' + escapeHtml(label) + '</option>';
            });

            sel.html(html);
        }

        function renderNmas() {
            var sel = $("#tmNmaSelect");
            if (!state.nmas || state.nmas.length === 0) {
                sel.html('<option value="">No NMAs found</option>');
                state.selectedNmaKey = null;
                state.selectedNmaIso3 = null;
                setMeta();
                return;
            }

            var html = '<option value="">-- Select NMA --</option>';
            state.nmas.forEach(function (n) {
                html += '<option value="' + escapeHtml(n.key) + '" data-iso3="' + escapeHtml(n.iso3 || "") + '">' + escapeHtml(n.name) + '</option>';
            });

            sel.html(html);
        }

        function renderTournamentTeams(rows) {
            var tbody = $("#tmTournamentRows");
            if (!rows || rows.length === 0) {
                tbody.html('<tr><td colspan="4">No tournament teams found for this event.</td></tr>');
                return;
            }

            var html = "";
            rows.forEach(function (t) {
                var isMapped = !!(t.nmaTeamKey) || !!(t.nmaTeamId);
                var iso3 = t.countryIso3 || "";
                html += '<tr data-teamkey="' + escapeHtml(t.key) + '">';
                html += '  <td>' + escapeHtml(t.name) + '</td>';
                html += '  <td>' + escapeHtml(iso3) + '</td>';
                html += '  <td>' + (isMapped ? '<span class="badge bg-success">Yes</span>' : '<span class="badge bg-secondary">No</span>') + '</td>';
                html += '  <td><input type="radio" name="tmTeamSelect" class="form-check-input tmTournamentSelect" value="' + escapeHtml(t.key) + '"></td>';
                html += '</tr>';
            });

            tbody.html(html);
        }

        function renderReportedTeams(rows) {
            var tbody = $("#tmReportedRows");

            if (!rows || rows.length === 0) {
                tbody.html('<tr><td colspan="4">No reported teams found.</td></tr>');
                return;
            }

            var html = "";
            rows.forEach(function (r) {
                html += '<tr data-reportedid="' + escapeHtml(r.id) + '" data-reportedkey="' + escapeHtml(r.key) + '" data-reportedname="' + escapeHtml(r.name) + '">';
                html += '  <td>' + escapeHtml(r.name) + '</td>';
                html += '  <td>' + escapeHtml(r.id) + '</td>';
                html += '  <td><span class="text-break" style="font-size:12px; color:#d63384;">' + escapeHtml(r.key) + '</span></td>';
                html += '  <td class="d-flex gap-2 flex-wrap">';
                html += '     <button type="button" class="btn btn-sm btn-success tmAdd">Add</button>';
                html += '     <button type="button" class="btn btn-sm btn-outline-primary tmLink">Link</button>';
                html += '  </td>';
                html += '</tr>';
            });

            tbody.html(html);
        }

        function loadEvents() {
            return $.ajax({
                url: "/umbraco/api/tournamentmanagement/events/current",
                method: "GET"
            }).then(function (res) {
                state.events = (res && res.items) ? res.items : [];
                renderEvents();
            });
        }

        function loadNmas() {
            return $.ajax({
                url: "/umbraco/api/tournamentmanagement/nmas",
                method: "GET"
            }).then(function (res) {
                state.nmas = (res && res.items) ? res.items : [];
                renderNmas();
            });
        }

        function loadTournamentTeams() {
            if (!state.selectedEventYearKey) {
                $("#tmTournamentRows").html('<tr><td colspan="4">Select an event to load teams.</td></tr>');
                return $.Deferred().resolve().promise();
            }

            return $.ajax({
                url: "/umbraco/api/tournamentmanagement/events/" + encodeURIComponent(state.selectedEventYearKey) + "/teams",
                method: "GET"
            }).then(function (res) {
                var rows = (res && res.items) ? res.items : [];
                state.tournamentTeams = rows;
                renderTournamentTeams(rows);
            }).fail(function (xhr) {
                showError(xhr && xhr.responseText ? xhr.responseText : "Failed to load tournament teams.");
            });
        }

        function loadReportedTeams(searchText) {
            if (!state.selectedNmaKey) {
                $("#tmReportedRows").html('<tr><td colspan="4">Select an NMA first.</td></tr>');
                return $.Deferred().resolve().promise();
            }
            if (!state.selectedAgeGroup) {
                $("#tmReportedRows").html('<tr><td colspan="4">Select an event first.</td></tr>');
                return $.Deferred().resolve().promise();
            }

            var srcYear = (state.selectedEventYear ? (parseInt(state.selectedEventYear, 10) - 1) : (new Date().getFullYear() - 1));
            state.sourceYear = srcYear;
            setMeta();

            return $.ajax({
                url: "/umbraco/api/tournamentmanagement/nmas/" + encodeURIComponent(state.selectedNmaKey) + "/teams",
                method: "GET",
                data: {
                    ageGroup: state.selectedAgeGroup,
                    year: srcYear,
                    q: (searchText || "").trim()
                }
            }).then(function (res) {
                state.sourceYear = res && res.year ? res.year : srcYear;
                setMeta();
                var rows = (res && res.items) ? res.items : [];
                renderReportedTeams(rows);
            }).fail(function (xhr) {
                showError(xhr && xhr.responseText ? xhr.responseText : "Failed to load reported teams.");
            });
        }

        function getSelectedTournamentTeamKey() {
            var key = $('input[name="tmTeamSelect"]:checked').val();
            return key || "";
        }

        function addTeam($reportedRow) {
            clearError();
            clearSuccess();

            if (!state.selectedEventYearKey) { showError("Select an event first."); return; }
            if (!state.selectedNmaKey) { showError("Select an NMA first."); return; }

            var payload = {
                eventYearKey: state.selectedEventYearKey, // kept for future use; server uses route
                nmaKey: state.selectedNmaKey,
                nmaIso3: state.selectedNmaIso3,
                reportedTeamId: parseInt($reportedRow.data("reportedid"), 10),
                reportedTeamKey: $reportedRow.data("reportedkey"),
                reportedTeamName: $reportedRow.data("reportedname")
            };

            return $.ajax({
                url: "/umbraco/api/tournamentmanagement/events/" + encodeURIComponent(state.selectedEventYearKey) + "/teams/add",
                method: "POST",
                contentType: "application/json",
                data: JSON.stringify(payload)
            }).then(function (res) {
                showSuccess((res && res.message) ? res.message : "Team added.");
                return loadTournamentTeams();
            }).fail(function (xhr) {
                showError(xhr && xhr.responseText ? xhr.responseText : "Failed to add team.");
            });
        }

        function linkTeam($reportedRow) {
            clearError();
            clearSuccess();

            if (!state.selectedEventYearKey) { showError("Select an event first."); return; }
            if (!state.selectedNmaKey) { showError("Select an NMA first."); return; }

            var tournamentTeamKey = getSelectedTournamentTeamKey();
            if (!tournamentTeamKey) { showError("Select a tournament team to link on the right-hand table."); return; }

            var payload = {
                tournamentTeamKey: tournamentTeamKey,
                nmaKey: state.selectedNmaKey,
                nmaIso3: state.selectedNmaIso3,
                TeamId: parseInt($reportedRow.data("reportedid"), 10),
                TeamKey: $reportedRow.data("reportedkey"),
                TeamName: $reportedRow.data("reportedname")
            };

            console.log(payload);

            return $.ajax({
                url: "/umbraco/api/tournamentmanagement/events/" + encodeURIComponent(state.selectedEventYearKey) + "/teams/link",
                method: "POST",
                contentType: "application/json",
                data: JSON.stringify(payload)
            }).then(function (res) {
                showSuccess((res && res.message) ? res.message : "Linked.");
                return loadTournamentTeams();
            }).fail(function (xhr) {
                showError(xhr && xhr.responseText ? xhr.responseText : "Failed to link team.");
            });
        }

        // Events
        $("#tmEventSelect").on("change", function () {
            var opt = $(this).find("option:selected");
            var key = opt.val();

            state.selectedEventYearKey = key || null;
            state.selectedEventYear = opt.data("year") || null;
            state.selectedAgeGroup = opt.data("agegroup") || null;

            state.sourceYear = null;
            setMeta();

            $("#tmReportedRows").html('<tr><td colspan="4">Select an NMA, then search.</td></tr>');

            loadTournamentTeams();
        });

        // NMAs
        $("#tmNmaSelect").on("change", function () {
            var opt = $(this).find("option:selected");
            var key = opt.val();
            state.selectedNmaKey = key || null;
            state.selectedNmaIso3 = opt.data("iso3") || null;

            state.sourceYear = null;
            setMeta();

            $("#tmReportedRows").html('<tr><td colspan="4">Search for reported teams.</td></tr>');
            loadReportedTeams($("#tmTeamSearch").val());
        });

        $("#tmRefreshBtn").on("click", function () {
            clearError();
            clearSuccess();
            $.when(loadEvents(), loadNmas()).then(function () {
                showSuccess("Refreshed.");
            }).fail(function (xhr) {
                showError(xhr && xhr.responseText ? xhr.responseText : "Failed to refresh.");
            });
        });

        $("#tmReloadTeamsBtn").on("click", function () {
            clearError();
            clearSuccess();
            loadTournamentTeams();
        });

        $("#tmTeamSearchBtn").on("click", function () {
            clearError();
            clearSuccess();
            loadReportedTeams($("#tmTeamSearch").val());
            
        });

        $(document).on("click", ".tmAdd", function () {
            var $tr = $(this).closest("tr");
            addTeam($tr);
        });

        $(document).on("click", ".tmLink", function () {
            var $tr = $(this).closest("tr");
            linkTeam($tr);
        });

        // init
        $.when(loadEvents(), loadNmas()).then(function () {
            setMeta();
        }).fail(function (xhr) {
            showError(xhr && xhr.responseText ? xhr.responseText : "Failed to initialise tournament management.");
        });

    })();
</script>